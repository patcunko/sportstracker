{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/nhl/:path*",      "destination": "/api/nhl/:path*" },
    { "source": "/espn-rss/:path*", "destination": "/api/espn-rss/:path*" },
    { "source": "/nba-stats/:path*","destination": "/api/nba-stats/:path*" },
    { "source": "/nba-cdn/:path*",  "destination": "/api/nba-cdn/:path*" }
  ]
}
